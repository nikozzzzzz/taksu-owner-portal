# Supabase
NEXT_PUBLIC_SUPABASE_URL=http://localhost:8000
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key, NEVER expose to client

# Resend (transactional emails)
RESEND_API_KEY=
EMAIL_FROM=portal@taksuliving.com

# App
NEXT_PUBLIC_APP_URL=https://portal.taksuliving.com
NEXT_PUBLIC_APP_NAME="Taksu Living Owner Portal"

# Security
SESSION_SECRET=                      # 32+ random chars, generate with: openssl rand -hex 32
RE_AUTH_TIMEOUT_MINUTES=15           # Timeout for sensitive actions re-auth

# Feature flags (Phase 2+)
NEXT_PUBLIC_FEATURE_AI_CHAT=false
NEXT_PUBLIC_FEATURE_2FA=false

# Monitoring (optional but recommended)
SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# Deployment (used by deploy.sh — not read by Next.js)
DEPLOY_HOST=             # IP or hostname of the target server
DEPLOY_USER=root         # SSH user
DEPLOY_DIR=/var/www/taksu-owner-portal
